{
  "manifestVersion": 5,
  "id": "com.liam.nanobanana.premiere.storyboard",
  "name": "Nano Banana Storyboard (PR)",
  "version": "1.0.0",
  "main": "index.html",
  "host": [
    { "app": "premierepro", "minVersion": "22.0.0" }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "nanoBananaPremierePanel",
      "label": { "default": "Nano Banana Storyboard" },
      "minimumSize": { "width": 260, "height": 360 },
      "maximumSize": { "width": 2000, "height": 2000 },
      "preferredDockedSize": { "width": 340, "height": 600 },
      "preferredFloatingSize": { "width": 360, "height": 640 }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": ["https://generativelanguage.googleapis.com"]
    },
    "localFileSystem": "fullAccess"
  }